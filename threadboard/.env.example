# Redis — Upstash recommended: https://upstash.com (free tier available)
REDIS_URL=rediss://default:xxxxxxxx@your-db.upstash.io:6379
STORAGE_URL=  # optional fallback for REDIS_URL

# Twilio SMS — https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# VAPID push notifications
# Generate with: ./scripts/generate-keys.sh
VAPID_EMAIL=mailto:you@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
